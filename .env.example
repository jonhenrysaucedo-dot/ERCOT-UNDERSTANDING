# ─────────────────────────────────────────────────────────────────────────────
# ERCOT DART — required environment variables
# Copy to .env and fill in values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── ERCOT MIS credentials ─────────────────────────────────────────────────────
# Register at: https://mis.ercot.com  (requires market participant approval)
ERCOT_MIS_USER=your_mis_username_here
ERCOT_MIS_PASS=your_mis_password_here

# ── Target node (provisional; confirmed via NP4-160-SG Settlement Points List)
# Do NOT hard-code this in any src/ file — always read from config/nodes.yaml
# or this env var. The name WILL change once the physical node energizes.
TARGET_NODE=QUANTUM_ESR

# ── EIA Open Data API ─────────────────────────────────────────────────────────
# Free signup: https://www.eia.gov/opendata/register.php
# Used for: Henry Hub natural gas spot price (series RNGWHHD, NP7-1-ID)
EIA_API_KEY=your_eia_api_key_here

# ── Open-Meteo ────────────────────────────────────────────────────────────────
# No API key needed for historical archive (ERA5 reanalysis, free tier).
# Set to 1 to use the commercial API (required if calling > 10k requests/day).
OPEN_METEO_COMMERCIAL=0
# OPEN_METEO_API_KEY=your_key_here   # only required if OPEN_METEO_COMMERCIAL=1

# ── Runtime ───────────────────────────────────────────────────────────────────
# Seed for all random sources (numpy, PyMC, hmmlearn). Logged with every run.
RANDOM_SEED=42

# ── Output ────────────────────────────────────────────────────────────────────
# Directory where bids_YYYYMMDD.csv and audit_YYYYMMDD.json are written.
OUTPUT_DIR=output
